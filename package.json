{
  "name": "tdl-desktop",
  "private": true,
  "version": "0.2.2",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "lint": "eslint .",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "fetch:tdl": "node scripts/fetch-tdl.mjs",
    "build:helper": "node scripts/build-helper.mjs",
    "release:collect": "node scripts/collect-release.mjs",
    "tauri": "tauri",
    "tauri:dev": "npm run fetch:tdl && tauri dev",
    "tauri:build": "npm run fetch:tdl && tauri build && npm run release:collect"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^8.0.13"
  }
}
